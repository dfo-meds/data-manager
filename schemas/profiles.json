{
  "$id": "https://cnodc-cndoc.azure.cloud-nuage.dfo-mpo.gc.ca/metadb/schemas/profiles.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "patternProperties": {
    "^[0-9a-zA-Z_]*$": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "display": { "$ref":  "shared.json#/$defs/label"},
        "extends": {
          "type":  ["string", "array"],
          "items": { "type":  "string" }
        },
        "preprocess": {
          "type": "array",
          "items": {"type":  "string"}
        },
        "validation": { "$ref": "shared.json#/$defs/validation" },
        "formatters": {
          "type": "object",
          "patternProperties": {
            "^[A-Za-z0-9_]*$": {
              "type": "object",
              "properties": {
                "label": {"$ref":  "shared.json#/$defs/label"},
                "template": {"type":  "string"},
                "content_type": {"type":  "string"},
                "preprocess": {"type":  "string"}
              }
            }
          }
        },
        "fields": {
          "type": "object",
          "patternProperties": {
            "^[a-z_]*$": {
              "$ref": "shared.json#/$defs/field"
            }
          }
        }
      }
    }
  }
}